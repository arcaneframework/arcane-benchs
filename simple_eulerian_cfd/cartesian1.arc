<?xml version="1.0"?>
<case codename="Arcane" xml:lang="en" codeversion="1.0">
  <arcane>
    <title>Simple Eulerian CFD</title>
    <description>Simple Eulerian CFD</description>
  </arcane>

 <meshes>
   <mesh>
     <generator name="Cartesian2D">
       <nb-part-x>2</nb-part-x> 
       <nb-part-y>2</nb-part-y>
       <origin>0.0 0.0</origin>
       <x><n>2</n><length>1.0</length></x>
       <y><n>2</n><length>1.0</length></y>
     </generator>
   </mesh>
 </meshes>

</case>
